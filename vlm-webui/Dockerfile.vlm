###############################################################################
# Dockerfile.vlm — live-vlm-webui for Jetson AGX Orin (ARM64 / JetPack 6.0)
# Source: https://github.com/nvidia-ai-iot/live-vlm-webui
###############################################################################

FROM nvcr.io/nvidia/l4t-jetpack:r36.4.0

ENV DEBIAN_FRONTEND=noninteractive
ARG LIVE_VLM_DEFAULT_INPUT_SOURCE=rtsp
ARG LIVE_VLM_DEFAULT_RTSP_URL=rtsp://realsense-rtsp:8554/d435i
ARG LIVE_VLM_DEFAULT_API_BASE=http://llama-cpp:8080/v1

# 系統依賴
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.11 python3-pip python3-dev \
    git curl libssl-dev \
    # WebRTC / aiortc 依賴
    libavformat-dev libavcodec-dev libavdevice-dev \
    libavutil-dev libswscale-dev libswresample-dev \
    # V4L2 (USB 鏡頭)
    v4l-utils \
    # RealSense D455 SDK
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Clone live-vlm-webui
RUN git clone --depth=1 https://github.com/nvidia-ai-iot/live-vlm-webui.git .
COPY patch-default-rtsp.py /tmp/patch-default-rtsp.py
RUN python3 /tmp/patch-default-rtsp.py \
    --input-source "${LIVE_VLM_DEFAULT_INPUT_SOURCE}" \
    --rtsp-url "${LIVE_VLM_DEFAULT_RTSP_URL}" \
    --api-base "${LIVE_VLM_DEFAULT_API_BASE}"

# Python 依賴（從專案 requirements.txt 安裝）
RUN pip3 install --no-cache-dir -r requirements.txt && \
    pip3 install --no-cache-dir \
    pyrealsense2 || true   # RealSense SDK（可選，無 D455 時跳過）

ENV PYTHONPATH=/app/src

# 環境變數（執行時可覆寫）
ENV LIVE_VLM_API_BASE=http://llama-cpp:8080/v1
ENV LIVE_VLM_PORT=8090
ENV LIVE_VLM_HOST=0.0.0.0
ENV LIVE_VLM_DEFAULT_INPUT_SOURCE=${LIVE_VLM_DEFAULT_INPUT_SOURCE}
ENV LIVE_VLM_DEFAULT_RTSP_URL=${LIVE_VLM_DEFAULT_RTSP_URL}
ENV LIVE_VLM_DEFAULT_API_BASE=${LIVE_VLM_DEFAULT_API_BASE}

EXPOSE 8090

CMD ["python3", "-m", "live_vlm_webui.server", \
     "--host", "0.0.0.0", \
     "--port", "8090", \
     "--api-base", "http://llama-cpp:8080/v1"]
